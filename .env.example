# Prisma - Supabase Postgres runtime connection.
# For Vercel/serverless and bulk import jobs use the Supabase transaction pooler:
# port 6543 plus pgbouncer=true. Keep connection_limit low for remote imports.
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require&connect_timeout=15"

# Optional dedicated connection string for bulk archive replay scripts. If set,
# import jobs use this instead of the app runtime DATABASE_URL. Keep it separate
# from Vercel runtime env and tune the pool deliberately.
DATABASE_IMPORT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=2&pool_timeout=30&sslmode=require&connect_timeout=15"
DATABASE_IMPORT_CONNECTION_LIMIT="1"
DATABASE_IMPORT_POOL_TIMEOUT="60"
DATABASE_IMPORT_CONNECT_TIMEOUT="30"

# Optional direct/session connection for Prisma CLI operations if your project
# exposes one. Do not use it for broad archive imports.
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres?sslmode=require&connect_timeout=15"

# Supabase API values. Required once Supabase-backed auth/storage/realtime paths
# are enabled in deployment. Never expose the service-role key to the browser.
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# App URL and server-side signing secret.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_SECRET="optional-same-value-as-NEXTAUTH_SECRET"

# WorkOS AuthKit
WORKOS_CLIENT_ID="client_YOUR_WORKOS_CLIENT_ID"
WORKOS_API_KEY="sk_test_YOUR_WORKOS_API_KEY"
WORKOS_COOKIE_PASSWORD="generate-at-least-32-characters"
NEXT_PUBLIC_WORKOS_REDIRECT_URI="http://localhost:3000/callback"

# Internal maintenance routes. Send this as the X-Internal-Secret header.
# Vercel Cron sends CRON_SECRET as Authorization: Bearer <secret>.
INTERNAL_API_SECRET="generate-with-openssl-rand-base64-32"
CRON_SECRET="generate-with-openssl-rand-base64-32"

# Optional live racing feed
TOPAZ_API_KEY=""
TOPAZ_API_BASE="https://topaz.grv.org.au/api"
TOPAZ_OWNING_AUTHORITY_CODE="VIC"
TOPAZ_TIME_ZONE="Australia/Sydney"

# Public all-Australia racecard source used for pre-production and live coverage
# verification. It covers national fields without replacing licensed feeds.
THEDOGS_PROVIDER_ENABLED="true"
THEDOGS_BASE_URL="https://www.thedogs.com.au"
THEDOGS_MAX_MEETINGS="80"
THEDOGS_CONCURRENCY="5"
THEDOGS_TIME_ZONE="Australia/Sydney"
THEDOGS_BACKFILL_FROM="2006-08-01"

# Public Victoria/GRV source for richer VIC fields, Watchdog tips, results, and
# replay IDs. The Dogs remains the national baseline for all-Australia coverage.
WATCHDOG_PROVIDER_ENABLED="true"
WATCHDOG_BASE_URL="https://watchdog.grv.org.au"
WATCHDOG_MAX_MEETINGS="40"
WATCHDOG_CONCURRENCY="4"
WATCHDOG_FETCH_TIMEOUT_MS="30000"

# Prototype-only public FastTrack fallback for the demo race feed. Topaz remains
# the licensed production feed where available.
FASTTRACK_PROTOTYPE_ENABLED="true"
FASTTRACK_BASE_URL="https://fasttrack.grv.org.au"
FASTTRACK_MAX_MEETINGS="1"

# Demo marketplace media. Keep enabled for pre-launch/dev; set false for live.
NEXT_PUBLIC_ENABLE_DEMO_LISTING_MEDIA="true"
NEXT_PUBLIC_ENABLE_DEMO_ACCOUNT="true"

# Optional smoke-test target
SMOKE_BASE_URL="http://localhost:3000"
