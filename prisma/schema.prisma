// GreyhoundIQ Prisma schema — SQLite for dev, swap to PostgreSQL for production
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ponytail: Supabase Postgres for dev + prod. Same Prisma client everywhere.

model Dog {
  id          String         @id @default(cuid())
  name        String
  earBrand    String?        @unique
  colour      String?
  sex         String?
  whelpDate   DateTime?
  sireId      String?
  damId       String?
  sire        Dog?           @relation("SireRelation", fields: [sireId], references: [id])
  dam         Dog?           @relation("DamRelation", fields: [damId], references: [id])
  progenySire Dog[]          @relation("SireRelation")
  progenyDam  Dog[]          @relation("DamRelation")
  trainerId   String?
  trainer     Trainer?       @relation(fields: [trainerId], references: [id])
  retiredAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  runners     Runner[]
  formEntries FormEntry[]
  ownership   DogOwnership[]
  listings    Listing[]

  @@index([name])
  @@index([sireId])
  @@index([damId])
}

model Trainer {
  id            String   @id @default(cuid())
  name          String
  state         String?
  licenseNumber String?
  dogs          Dog[]
  runners       Runner[]
  createdAt     DateTime @default(now())

  @@index([name])
}

model Track {
  id             String      @id @default(cuid())
  name           String
  state          String
  surface        String?
  circumference  Int?
  straightLength Int?
  boxCount       Int         @default(8)
  hasIsolynx     Boolean     @default(false)
  meetings       Meeting[]
  formEntries    FormEntry[]
  createdAt      DateTime    @default(now())

  @@index([name])
  @@index([state])
}

model Meeting {
  id          String   @id @default(cuid())
  trackId     String
  track       Track    @relation(fields: [trackId], references: [id])
  meetingDate DateTime
  meetingType String?
  races       Race[]
  createdAt   DateTime @default(now())

  @@index([trackId])
  @@index([meetingDate])
}

model Race {
  id         String   @id @default(cuid())
  meetingId  String
  meeting    Meeting  @relation(fields: [meetingId], references: [id])
  raceNumber Int
  raceTime   DateTime
  distance   Int
  grade      String?
  prizeMoney Float?
  runners    Runner[]
  createdAt  DateTime @default(now())

  @@index([meetingId])
  @@index([raceTime])
}

model Runner {
  id            String   @id @default(cuid())
  raceId        String
  race          Race     @relation(fields: [raceId], references: [id])
  dogId         String
  dog           Dog      @relation(fields: [dogId], references: [id])
  boxNumber     Int
  weight        Float?
  trainerId     String?
  trainer       Trainer? @relation(fields: [trainerId], references: [id])
  startingPrice Float?
  scratched     Boolean  @default(false)
  result        Result?
  createdAt     DateTime @default(now())

  @@index([raceId])
  @@index([dogId])
}

model Result {
  id                String   @id @default(cuid())
  runnerId          String   @unique
  runner            Runner   @relation(fields: [runnerId], references: [id])
  raceId            String
  finishingPosition Int?
  runningTime       Float?
  margin            Float?
  splitTime         Float?
  sectionals        String?
  gpsData           String?
  createdAt         DateTime @default(now())

  @@index([raceId])
}

model FormEntry {
  id        String   @id @default(cuid())
  dogId     String
  dog       Dog      @relation(fields: [dogId], references: [id])
  raceId    String?
  trackId   String?
  track     Track?   @relation(fields: [trackId], references: [id])
  date      DateTime
  boxNumber Int?
  finish    Int?
  time      Float?
  distance  Int?
  grade     String?
  weight    Float?
  createdAt DateTime @default(now())

  @@index([dogId])
  @@index([date])
}

model User {
  id                   String   @id @default(cuid())
  email                String   @unique
  name                 String?
  subscriptionTier     String   @default("free")
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  isBanned             Boolean  @default(false)
  deletionRequestedAt  DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Supabase auth links this table via supabase_auth_uid
  supabaseUid String? @unique

  // ponytail: community relations are on Profile (1:1), not User.
  // Access via user.profile.posts etc — no redundant FKs here.
  profile        Profile?
  reportsFiled   Report[] @relation("Reporter")
  reportsAgainst Report[] @relation("Reported")
  mediaAssets    MediaAsset[]
  memoryEntries  MemoryEntry[]
  agentContexts  ConversationContext[]
}

// === COMMUNITY ===

model Profile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  displayName  String
  bio          String?
  avatarUrl    String?
  state        String?
  kennelName   String?
  kennelPrefix String?
  role         String   @default("member") // member | breeder | trainer | admin
  verified     Boolean  @default(false)
  website      String?
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  posts            Post[]
  threads          Thread[]
  listings         Listing[]
  messagesSent     Message[]      @relation("SenderMessages")
  messagesReceived Message[]      @relation("RecipientMessages")
  conversationsA   Conversation[] @relation("ConversationA")
  conversationsB   Conversation[] @relation("ConversationB")
  dogsOwned        DogOwnership[]
}

model DogOwnership {
  id        String   @id @default(cuid())
  dogId     String
  dog       Dog      @relation(fields: [dogId], references: [id])
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])
  role      String // owner | breeder | trainer | co-owner
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([dogId, profileId])
}

model ForumCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0)
  threads     Thread[]
}

model Thread {
  id         String        @id @default(cuid())
  categoryId String
  category   ForumCategory @relation(fields: [categoryId], references: [id])
  title      String
  authorId   String
  author     Profile       @relation(fields: [authorId], references: [id])
  pinned     Boolean       @default(false)
  locked     Boolean       @default(false)
  views      Int           @default(0)
  posts      Post[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([categoryId])
}

model Post {
  id        String    @id @default(cuid())
  threadId  String
  thread    Thread    @relation(fields: [threadId], references: [id])
  authorId  String
  author    Profile   @relation(fields: [authorId], references: [id])
  body      String
  editedAt  DateTime?
  createdAt DateTime  @default(now())

  @@index([threadId])
}

model Listing {
  id          String   @id @default(cuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id])
  type        String // pup_for_sale | dog_for_sale | stud_service | wanted
  title       String
  description String
  price       Float?
  currency    String   @default("AUD")
  state       String?
  dogId       String?
  dog         Dog?     @relation(fields: [dogId], references: [id])
  imageUrl    String?
  status      String   @default("active") // active | expired | sold | withdrawn | archived
  expiresAt   DateTime?
  soldAt      DateTime?
  archivedAt  DateTime?
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  media       ListingMedia[]

  @@index([profileId])
  @@index([type])
  @@index([status])
  @@index([expiresAt])
  @@index([soldAt])
}

model Message {
  id                   String        @id @default(cuid())
  conversationId       String?
  conversation         Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId             String
  sender               Profile       @relation("SenderMessages", fields: [senderId], references: [id])
  recipientId          String
  recipient            Profile       @relation("RecipientMessages", fields: [recipientId], references: [id])
  body                 String
  mediaIdsJson         String?
  read                 Boolean       @default(false)
  readAt               DateTime?
  deletedBySenderAt    DateTime?
  deletedByRecipientAt DateTime?
  createdAt            DateTime      @default(now())
  media                MessageMedia[]

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([recipientId])
}

model MediaAsset {
  id              String    @id @default(cuid())
  uploaderId      String
  uploader        User      @relation(fields: [uploaderId], references: [id])
  storageBucket   String
  storagePath     String
  originalName    String?
  mimeType        String
  sizeBytes       Int
  widthPx         Int?
  heightPx        Int?
  durationSec     Float?
  scanStatus      String    @default("pending") // pending | clean | infected | error
  scanCompletedAt DateTime?
  sha256          String?
  expiresAt       DateTime?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  messageAttachments MessageMedia[]
  listingAttachments ListingMedia[]

  @@unique([storageBucket, storagePath])
  @@index([uploaderId, createdAt])
  @@index([uploaderId, sha256])
  @@index([scanStatus])
}

model MessageMedia {
  messageId String
  message   Message    @relation(fields: [messageId], references: [id], onDelete: Cascade)
  mediaId   String
  media     MediaAsset @relation(fields: [mediaId], references: [id])
  position  Int
  createdAt DateTime   @default(now())

  @@id([messageId, mediaId])
  @@unique([messageId, position])
  @@index([mediaId])
}

model ListingMedia {
  listingId String
  listing   Listing    @relation(fields: [listingId], references: [id], onDelete: Cascade)
  mediaId   String
  media     MediaAsset @relation(fields: [mediaId], references: [id])
  position  Int
  createdAt DateTime   @default(now())

  @@id([listingId, mediaId])
  @@unique([listingId, position])
  @@index([mediaId])
}

model Conversation {
  id             String    @id @default(cuid())
  participantAId String
  participantA   Profile   @relation("ConversationA", fields: [participantAId], references: [id])
  participantBId String
  participantB   Profile   @relation("ConversationB", fields: [participantBId], references: [id])
  lastMessageAt  DateTime?
  blockedById    String?
  blockedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  messages       Message[]

  @@unique([participantAId, participantBId])
  @@index([participantAId])
  @@index([participantBId])
  @@index([lastMessageAt])
}

// === AGENTS ===

model AgentRun {
  id               String    @id @default(cuid())
  agentType        String // race_analyst | breeding_advisor | form_reader | moderator
  userId           String? // null for cron-triggered
  inputJson        String // JSON: input params
  outputJson       String? // JSON: structured result
  toolInvocations  String?
  createdMemoryIds String?
  status           String    @default("pending") // pending | running | completed | failed
  error            String?
  promptTokens     Int?
  completionTokens Int?
  durationMs       Int?
  harnessPid       Int?
  harnessSessionId String?
  createdAt        DateTime  @default(now())
  completedAt      DateTime?

  @@index([agentType])
  @@index([userId, createdAt])
  @@index([userId])
  @@index([status])
}

model MemoryEntry {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind           String // episodic | semantic | preference | unfinished
  content        String
  source         String // conversation | explicit_user_input | agent_inference | tool_observation
  sourceRef      String?
  importance     Float     @default(0.5)
  lastAccessedAt DateTime  @default(now())
  lastMaintainedAt DateTime?
  accessCount    Int       @default(0)
  supersededById String?
  supersededAt   DateTime?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId, kind])
  @@index([userId, importance])
  @@index([userId, lastAccessedAt])
  @@index([lastMaintainedAt])
}

model ConversationContext {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentType     String
  lastMessageAt DateTime @default(now())
  pendingAction String?
  windowSize    Int      @default(50)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, agentType])
  @@index([userId, updatedAt])
}

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  actorId    String?
  actorType  String
  action     String
  targetType String?
  targetId   String?
  ip         String?
  userAgent  String?
  metadata   String?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
}

model Report {
  id              String   @id @default(cuid())
  reporterId      String
  reporter        User     @relation("Reporter", fields: [reporterId], references: [id])
  reportedId      String?
  reported        User?    @relation("Reported", fields: [reportedId], references: [id])
  targetType      String
  targetId        String
  reason          String
  description     String?
  status          String   @default("open")
  resolvedBy      String?
  resolvedAt      DateTime?
  resolutionNotes String?
  createdAt       DateTime @default(now())

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@index([reporterId, targetType, targetId, createdAt])
}
